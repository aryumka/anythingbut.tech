---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="home">
			<section class="hero">
				<h1 class="title">{SITE_TITLE}</h1>
			</section>

			<section class="posts">
				<div class="posts-track">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<img
									src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src}
									alt={post.data.title}
									class="post-thumb"
								/>
							)}
							<div class="post-info">
								<span class="post-date">
									{post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
								</span>
								<h2 class="post-title">{post.data.title}</h2>
							</div>
						</a>
					))}
				</div>
			</section>
		</div>

		<style>
			.home {
				display: flex;
				flex-direction: column;
				height: calc(100dvh - 44px);
				overflow: hidden;
			}

			.hero {
				flex: 1;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.title {
				font-size: clamp(1.6rem, 4vw, 2.8rem);
				font-weight: 400;
				letter-spacing: 0.02em;
				color: #222;
			}

			.posts {
				flex: 1;
				display: flex;
				align-items: center;
				overflow: hidden;
				padding: 0 2.5rem;
			}
			.posts-track {
				display: flex;
				gap: 2rem;
				overflow-x: auto;
				scroll-snap-type: x mandatory;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;
				padding: 1.5rem 0;
			}
			.posts-track::-webkit-scrollbar {
				display: none;
			}

			.post-card {
				flex: 0 0 260px;
				scroll-snap-align: start;
				display: flex;
				flex-direction: column;
				text-decoration: none;
				color: #222;
				transition: opacity 0.2s;
			}
			.post-card:hover {
				opacity: 0.7;
			}

			.post-thumb {
				width: 100%;
				height: 200px;
				object-fit: cover;
			}

			.post-info {
				padding: 0.8rem 0;
			}
			.post-date {
				font-size: 0.7rem;
				color: #bbb;
				letter-spacing: 0.03em;
				display: block;
				margin-bottom: 0.3rem;
			}
			.post-title {
				font-size: 0.95rem;
				font-weight: 400;
				line-height: 1.5;
				color: #222;
			}

			@media (max-width: 768px) {
				.home {
					height: auto;
					overflow: visible;
				}
				.hero {
					min-height: 35vh;
				}
				.posts {
					overflow: visible;
					padding: 0 1.2rem;
				}
				.posts-track {
					flex-direction: column;
					overflow-x: visible;
					scroll-snap-type: none;
					width: 100%;
					gap: 1.5rem;
					padding-bottom: 2rem;
				}
				.post-card {
					flex: none;
					width: 100%;
				}
				.post-thumb {
					height: 220px;
				}
			}
		</style>
	</body>
</html>