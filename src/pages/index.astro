---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="page">
			<Header />

			<section class="hero">
				<h1 class="hero-title">{SITE_TITLE}</h1>
			</section>

			<section class="posts-section">
				<div class="posts-track">
					{posts.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="post-card" style={`animation-delay: ${0.2 + i * 0.1}s`}>
							<div class="card-header">
								<span class="card-number">{String(posts.length - i).padStart(2, '0')}</span>
							</div>
							<div class="card-title">{post.data.title}</div>
							{post.data.description && (
								<div class="card-excerpt">{post.data.description}</div>
							)}
							<div class="card-date">
								{post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
							</div>
						</a>
					))}
				</div>
			</section>
		</div>

		<script>
			function checkOverflow() {
				const track = document.querySelector('.posts-track');
				const section = document.querySelector('.posts-section');
				if (!track || !section) return;
				const hasOverflow = track.scrollWidth > track.clientWidth + 1;
				const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10;
				if (hasOverflow && !atEnd) {
					section.classList.add('has-overflow');
				} else {
					section.classList.remove('has-overflow');
				}
			}
			const track = document.querySelector('.posts-track');
			window.addEventListener('load', checkOverflow);
			window.addEventListener('resize', checkOverflow);
			if (track) track.addEventListener('scroll', checkOverflow);
		</script>

		<style>
			body { overflow: hidden; }

			.page {
				display: flex;
				flex-direction: column;
				height: 100vh;
				height: 100dvh;
			}

			/* Hero */
			.hero {
				flex: 1;
				display: flex;
				justify-content: center;
				align-items: center;
				text-align: center;
				padding: 0 48px;
			}
			.hero-title {
				font-family: var(--display);
				font-size: clamp(38px, 5.5vw, 72px);
				font-weight: 400;
				letter-spacing: 0.01em;
				line-height: 1.3;
				color: var(--text);
				animation: fadeUp 0.7s ease forwards;
				opacity: 0;
			}

			/* Posts */
			.posts-section {
				flex-shrink: 0;
				min-height: 200px;
				border-top: 1px solid rgba(0,0,0,0.06);
				position: relative;
			}
			.posts-section::after {
				content: '';
				position: absolute;
				top: 0;
				right: 0;
				bottom: 0;
				width: 120px;
				background: linear-gradient(to right, transparent, var(--bg));
				pointer-events: none;
				z-index: 1;
				opacity: 0;
				transition: opacity 0.3s;
			}
			.posts-section.has-overflow::after {
				opacity: 1;
			}

			.posts-track {
				display: flex;
				overflow-x: auto;
				overflow-y: hidden;
				scroll-snap-type: x mandatory;
				scrollbar-width: none;
			}
			.posts-track::-webkit-scrollbar { display: none; }

			.post-card {
				flex: 1 0 280px;
				max-width: 400px;
				scroll-snap-align: start;
				cursor: pointer;
				text-decoration: none;
				color: inherit;
				padding: 24px 32px 28px;
				border-right: 1px solid rgba(0,0,0,0.06);
				transition: background 0.3s ease;
				animation: fadeUp 0.5s ease forwards;
				opacity: 0;
			}
			.post-card:first-child {
				padding-left: 48px;
			}
			.post-card:last-child {
				border-right: none;
			}
			.post-card:hover {
				background: #F5F5F5;
			}

			.card-header {
				display: flex;
				align-items: baseline;
				gap: 8px;
				margin-bottom: 14px;
			}
			.card-number {
				font-family: var(--display);
				font-size: 13px;
				color: rgba(0,0,0,0.2);
			}

			.card-title {
				font-family: var(--sans);
				font-size: 16px;
				font-weight: 600;
				line-height: 1.4;
				color: var(--text);
				margin-bottom: 8px;
				letter-spacing: -0.01em;
			}
			.card-excerpt {
				font-family: var(--sans);
				font-size: 12.5px;
				font-weight: 400;
				color: #999;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
				margin-bottom: 12px;
			}
			.card-date {
				font-family: var(--sans);
				font-size: 11px;
				color: var(--text-muted);
				font-weight: 300;
			}

			@media (max-width: 768px) {
				.hero { padding: 0 24px; }
				.post-card { width: 260px; padding: 20px 24px 24px; }
				.post-card:first-child { padding-left: 24px; width: 260px; }
			}
		</style>
	</body>
</html>
