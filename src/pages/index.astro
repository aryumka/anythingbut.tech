---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="home">
			<section class="hero">
				<h1 class="title">{SITE_TITLE}</h1>
			</section>

			<section class="posts">
				<div class="posts-track">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<img
									src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src}
									alt={post.data.title}
									class="post-thumb"
								/>
							)}
							<div class="post-info">
								<span class="post-date">
									{post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
								</span>
								<h2 class="post-title">{post.data.title}</h2>
							</div>
						</a>
					))}
				</div>
			</section>
		</div>

		<style>
			.home {
				display: flex;
				flex-direction: column;
				height: 100dvh;
				overflow: hidden;
			}

			/* Top half - title */
			.hero {
				flex: 1;
				display: flex;
				align-items: center;
				justify-content: center;
				border-bottom: 1px solid #000;
			}
			.title {
				font-size: clamp(1.8rem, 5vw, 3.5rem);
				font-weight: 700;
				letter-spacing: -0.02em;
			}

			/* Bottom half - horizontal scroll */
			.posts {
				flex: 1;
				display: flex;
				align-items: stretch;
				overflow: hidden;
			}
			.posts-track {
				display: flex;
				gap: 0;
				overflow-x: auto;
				scroll-snap-type: x mandatory;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;
			}
			.posts-track::-webkit-scrollbar {
				display: none;
			}

			.post-card {
				flex: 0 0 320px;
				scroll-snap-align: start;
				display: flex;
				flex-direction: column;
				border-right: 1px solid #000;
				text-decoration: none;
				color: #000;
				transition: background 0.2s;
			}
			.post-card:hover {
				background: #f5f5f5;
				opacity: 1;
			}

			.post-thumb {
				width: 100%;
				height: 60%;
				object-fit: cover;
				border-radius: 0;
			}

			.post-info {
				flex: 1;
				display: flex;
				flex-direction: column;
				justify-content: center;
				padding: 1.2rem 1.5rem;
			}
			.post-date {
				font-size: 0.8rem;
				color: #888;
				margin-bottom: 0.4rem;
			}
			.post-title {
				font-size: 1.1rem;
				font-weight: 700;
				line-height: 1.4;
				letter-spacing: -0.01em;
			}

			/* Mobile: stack vertically */
			@media (max-width: 768px) {
				.home {
					height: auto;
					overflow: visible;
				}
				.hero {
					min-height: 40vh;
				}
				.posts {
					overflow: visible;
				}
				.posts-track {
					flex-direction: column;
					overflow-x: visible;
					scroll-snap-type: none;
				}
				.post-card {
					flex: none;
					width: 100%;
					flex-direction: row;
					height: 120px;
					border-right: none;
					border-bottom: 1px solid #000;
				}
				.post-thumb {
					width: 120px;
					height: 100%;
				}
				.post-info {
					padding: 1rem;
				}
			}
		</style>
	</body>
</html>