---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="home">
			<section class="hero">
				<h1 class="title">{SITE_TITLE}</h1>
			</section>

			<section class="posts">
				<div class="posts-track">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<img
									src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src}
									alt={post.data.title}
									class="post-thumb"
								/>
							)}
							<div class="post-info">
								<span class="post-date">
									{post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
								</span>
								<h2 class="post-title">{post.data.title}</h2>
							</div>
						</a>
					))}
				</div>
			</section>
		</div>

		<style>
			.home {
				display: flex;
				flex-direction: column;
				height: calc(100dvh - 56px);
				overflow: hidden;
			}

			/* Top half - title */
			.hero {
				flex: 1;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.title {
				font-size: clamp(2.2rem, 6vw, 4.5rem);
				font-weight: 900;
				letter-spacing: 0.15em;
			}

			/* Bottom half - horizontal scroll */
			.posts {
				flex: 1;
				display: flex;
				align-items: center;
				overflow: hidden;
				padding: 0 2rem;
			}
			.posts-track {
				display: flex;
				gap: 1.5rem;
				overflow-x: auto;
				scroll-snap-type: x mandatory;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;
				padding: 1rem 0;
			}
			.posts-track::-webkit-scrollbar {
				display: none;
			}

			.post-card {
				flex: 0 0 280px;
				scroll-snap-align: start;
				display: flex;
				flex-direction: column;
				border-radius: 12px;
				overflow: hidden;
				text-decoration: none;
				color: #000;
				background: #fff;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
				transition: box-shadow 0.2s, transform 0.2s;
			}
			.post-card:hover {
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
				transform: translateY(-2px);
				opacity: 1;
			}

			.post-thumb {
				width: 100%;
				height: 180px;
				object-fit: cover;
			}

			.post-info {
				padding: 1rem 1.2rem;
			}
			.post-date {
				font-size: 0.8rem;
				color: #888;
				margin-bottom: 0.4rem;
				display: block;
			}
			.post-title {
				font-size: 1rem;
				font-weight: 700;
				line-height: 1.4;
				letter-spacing: -0.01em;
			}

			/* Mobile: stack vertically */
			@media (max-width: 768px) {
				.home {
					height: auto;
					overflow: visible;
				}
				.hero {
					min-height: 40vh;
				}
				.posts {
					overflow: visible;
					padding: 0 1rem;
				}
				.posts-track {
					flex-direction: column;
					overflow-x: visible;
					scroll-snap-type: none;
					width: 100%;
					padding-bottom: 2rem;
				}
				.post-card {
					flex: none;
					width: 100%;
					flex-direction: row;
					height: 120px;
				}
				.post-thumb {
					width: 120px;
					height: 100%;
				}
				.post-info {
					display: flex;
					flex-direction: column;
					justify-content: center;
				}
			}
		</style>
	</body>
</html>
