---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">anythingbut.tech</a>
		<div class="nav-links">
			<HeaderLink href="/blog">Posts</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="spacer"></div>
	</nav>
</header>

<style>
	header {
		padding: 1rem 2rem;
	}
	nav {
		display: flex;
		align-items: center;
	}
	.site-title {
		font-size: 0.9rem;
		font-weight: 700;
		color: #000;
		text-decoration: none;
	}
	.site-title:hover {
		opacity: 0.6;
	}
	.nav-links {
		display: flex;
		gap: 1.5rem;
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
	}
	.spacer {
		flex: 1;
	}
</style>