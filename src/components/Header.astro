---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">anythingbut.tech</a>
		<div class="nav-links">
			<HeaderLink href="/blog">Posts</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		padding: 0.8rem 2.5rem;
	}
	nav {
		display: flex;
		align-items: center;
		position: relative;
	}
	.site-title {
		font-size: 0.95rem;
		font-weight: 400;
		color: #999;
		text-decoration: none;
		letter-spacing: 0.05em;
	}
	.site-title:hover {
		color: #000;
	}
	.nav-links {
		display: flex;
		gap: 2rem;
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
	}
</style>