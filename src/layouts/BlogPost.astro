---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: any;
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
}

const { title, description, pubDate, updatedDate, heroImage, prevPost, nextPost } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
	</head>

	<body>
		<div class="progress-bar" id="progress"></div>
		<Header />

		<header class="article-header">
			<div class="article-meta">
				<span class="article-date">
					{pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
				</span>
				{updatedDate && (
					<span class="article-meta-dot"></span>
					<span class="article-date">
						수정: {updatedDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
					</span>
				)}
			</div>
			<h1 class="article-title">{title}</h1>
			{description && (
				<p class="article-excerpt">{description}</p>
			)}
		</header>

		<article class="article-body">
			<slot />
		</article>

		{(prevPost || nextPost) && (
			<footer class="article-footer">
				<div class="footer-divider"></div>
				<div class="footer-nav">
					{prevPost && (
						<a href={`/blog/${prevPost.id}/`} class="footer-nav-item prev">
							<div class="footer-nav-label">&larr; 이전 글</div>
							<div class="footer-nav-title">{prevPost.data.title}</div>
						</a>
					)}
					{nextPost && (
						<a href={`/blog/${nextPost.id}/`} class="footer-nav-item next">
							<div class="footer-nav-label">다음 글 &rarr;</div>
							<div class="footer-nav-title">{nextPost.data.title}</div>
						</a>
					)}
				</div>
			</footer>
		)}

		<script>
			window.addEventListener('scroll', () => {
				const doc = document.documentElement;
				const scrollTop = doc.scrollTop;
				const scrollHeight = doc.scrollHeight - doc.clientHeight;
				const progress = (scrollTop / scrollHeight) * 100;
				const el = document.getElementById('progress');
				if (el) el.style.width = progress + '%';
			});
		</script>

		<style>
			html { scroll-behavior: smooth; }

			.progress-bar {
				position: fixed;
				top: 0;
				left: 0;
				height: 2px;
				background: var(--text);
				width: 0%;
				z-index: 100;
				transition: width 0.1s linear;
			}

			.article-header {
				max-width: 640px;
				margin: 0 auto;
				padding: 80px 48px 0;
				animation: fadeUp 0.7s ease forwards;
				opacity: 0;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 16px;
				margin-bottom: 24px;
			}

			.article-meta-dot {
				width: 3px;
				height: 3px;
				border-radius: 50%;
				background: var(--text-muted);
				opacity: 0.5;
			}

			.article-date {
				font-family: var(--sans);
				font-size: 12px;
				font-weight: 300;
				color: var(--text-muted);
			}

			.article-title {
				font-family: var(--display);
				font-size: clamp(28px, 4vw, 40px);
				font-weight: 400;
				line-height: 1.35;
				color: var(--text);
				margin-bottom: 24px;
			}

			.article-excerpt {
				font-family: var(--sans);
				font-size: 16px;
				font-weight: 300;
				line-height: 1.7;
				color: var(--text-muted);
				padding-bottom: 24px;
				border-bottom: 1px solid rgba(0,0,0,0.06);
			}

			.article-body {
				max-width: 640px;
				margin: 0 auto;
				padding: 48px 48px 120px;
				animation: fadeUp 0.7s ease forwards;
				animation-delay: 0.15s;
				opacity: 0;
			}

			.article-body :global(p) {
				font-family: var(--sans);
				font-size: 15.5px;
				font-weight: 200;
				line-height: 1.95;
				color: var(--text-body);
				margin-bottom: 32px;
			}

			.article-body :global(strong) {
				font-weight: 500;
				color: var(--text);
			}

			.article-body :global(h2) {
				font-family: var(--sans);
				font-size: 20px;
				font-weight: 600;
				color: var(--text);
				margin-top: 56px;
				margin-bottom: 24px;
				letter-spacing: -0.01em;
			}

			.article-body :global(h3) {
				font-family: var(--sans);
				font-size: 17px;
				font-weight: 600;
				color: var(--text);
				margin-top: 40px;
				margin-bottom: 16px;
			}

			.article-body :global(blockquote) {
				margin: 40px 0;
				padding: 0 0 0 24px;
				border-left: 2px solid rgba(0,0,0,0.1);
			}

			.article-body :global(blockquote p) {
				font-size: 15px;
				font-style: italic;
				color: var(--text-muted);
				margin-bottom: 0;
			}

			.article-body :global(a) {
				color: var(--text);
				text-decoration: underline;
				text-decoration-color: rgba(0,0,0,0.2);
				text-underline-offset: 3px;
				transition: text-decoration-color 0.3s;
			}
			.article-body :global(a:hover) {
				text-decoration-color: var(--text);
			}

			.article-body :global(code) {
				font-family: 'SF Mono', 'Fira Code', monospace;
				font-size: 13.5px;
				background: #F4F4F4;
				padding: 2px 6px;
				border-radius: 3px;
				color: var(--text);
			}

			.article-body :global(pre) {
				background: #F8F8F8;
				border-radius: 6px;
				padding: 24px;
				overflow-x: auto;
				margin: 32px 0;
			}

			.article-body :global(pre code) {
				background: none;
				padding: 0;
				font-size: 13px;
				line-height: 1.7;
				color: var(--text-body);
			}

			.article-body :global(img) {
				width: 100%;
				border-radius: 4px;
				margin: 40px 0;
			}

			.article-body :global(hr) {
				border: none;
				height: 1px;
				background: rgba(0,0,0,0.06);
				margin: 56px 0;
			}

			.article-body :global(ul),
			.article-body :global(ol) {
				font-family: var(--sans);
				font-size: 15.5px;
				font-weight: 300;
				line-height: 1.95;
				color: var(--text-body);
				margin-bottom: 32px;
				padding-left: 24px;
			}

			.article-body :global(li) {
				margin-bottom: 8px;
			}

			/* Footer nav */
			.article-footer {
				max-width: 640px;
				margin: 0 auto;
				padding: 0 48px 120px;
			}

			.footer-divider {
				height: 1px;
				background: rgba(0,0,0,0.06);
				margin-bottom: 40px;
			}

			.footer-nav {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
			}

			.footer-nav-item {
				text-decoration: none;
				color: inherit;
				max-width: 45%;
				transition: opacity 0.3s;
			}
			.footer-nav-item:hover { opacity: 0.6; }

			.footer-nav-item.next {
				text-align: right;
				margin-left: auto;
			}

			.footer-nav-label {
				font-family: var(--sans);
				font-size: 10px;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--text-muted);
				margin-bottom: 8px;
			}

			.footer-nav-title {
				font-family: var(--sans);
				font-size: 15px;
				font-weight: 500;
				color: var(--text);
				line-height: 1.4;
			}

			@media (max-width: 768px) {
				.article-header { padding: 48px 24px 0; }
				.article-body { padding: 36px 24px 80px; }
				.article-footer { padding: 0 24px 80px; }
			}
		</style>
	</body>
</html>